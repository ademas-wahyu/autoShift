# ── Database ─────────────────────────────────────────
# Driver: postgres | sqlite | mysql | sqlserver
DB_DRIVER=postgres

# PostgreSQL / MySQL / SQL Server
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=autoshift
DB_SSLMODE=disable

# SQLite only (used when DB_DRIVER=sqlite)
DB_PATH=autoshift.db

# ── Server ───────────────────────────────────────────
SERVER_PORT=8080
JWT_SECRET=change-me-to-a-random-secret

# ── Holiday API ──────────────────────────────────────
HOLIDAY_API_URL=https://date.nager.at/api/v3

# ── AI Generator ─────────────────────────────────────
# Provider: mock | openai
AI_PROVIDER=mock

# OpenAI-compatible API endpoint (Ollama, vLLM, etc.)
# Set AI_API_KEY only if the endpoint requires auth
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=
AI_MODEL=gpt-4o
